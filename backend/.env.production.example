# Agentic Marketplace — Backend Production Environment
# Copy to backend/.env.production and fill in values

# ── Application ──────────────────────────────────────────
APP_NAME=Agentic Marketplace
APP_ENV=production
APP_DEBUG=false
APP_DOMAIN=agenticmarketplace.com

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentic:CHANGE_ME@postgres:5432/agentic_marketplace

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Qdrant ────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── MinIO / S3 ───────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET_NAME=agentic-marketplace
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# ── JWT / Auth ────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32BYTE_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenRouter (AI Gateway) ──────────────────────────────
OPENROUTER_API_KEY=CHANGE_ME_YOUR_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=anthropic/claude-sonnet-4

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLIC_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@agenticmarketplace.com
SMTP_PASSWORD=CHANGE_ME
EMAILS_FROM_NAME=Agentic Marketplace
EMAILS_FROM_EMAIL=noreply@agenticmarketplace.com

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL=https://agenticmarketplace.com
ALLOWED_ORIGINS=["https://agenticmarketplace.com","https://www.agenticmarketplace.com"]
