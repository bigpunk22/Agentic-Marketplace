# Agentic Marketplace — Frontend Production Environment
# Copy to frontend/.env.production and fill in values

# ── API ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://agenticmarketplace.com
NEXT_PUBLIC_WS_URL=wss://agenticmarketplace.com

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Agentic Marketplace
NEXT_PUBLIC_APP_URL=https://agenticmarketplace.com

# ── Analytics (optional) ─────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_ID=

# ── Feature Flags ────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
